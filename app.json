{
  "expo": {
    "name": "NativeMusicPlayer",
    "slug": "NativeMusicPlayer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/google.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tasselhat.NativeMusicPlayer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1df7bdc2-5023-474e-9352-ee2b61203a04"
      }
    }
  }
}
